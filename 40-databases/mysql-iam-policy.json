{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SSMGetParameter",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:GetParameters"
      ],
      "Resource": "arn:aws:ssm:us-east-1:903669075061:parameter/roboshop/${environment}/mysql_root_password"
    },
    {
      "Sid": "KMSDecrypt",
      "Effect": "Allow",
      "Action": "kms:Decrypt",
      "Resource": "arn:aws:kms:us-east-1:903669075061:alias/aws/ssm"
    }
  ]
}